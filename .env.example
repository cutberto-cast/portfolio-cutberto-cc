# Configuración de entorno - Copiar a .env.local

# Requerida: API key de Resend (https://resend.com/api-keys), usada por
# app/api/contact/route.ts para enviar el correo del formulario de contacto.
RESEND_API_KEY=

# Opcional: URL pública del sitio, usada en metadata (Open Graph), robots.ts
# y sitemap.ts. Por defecto http://localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
